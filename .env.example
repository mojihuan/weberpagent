# ============================================
# LLM Configuration
# ============================================
# Primary API key (DashScope for Qwen, or OpenAI)
DASHSCOPE_API_KEY=sk-xxx
OPENAI_API_KEY=sk-xxx

# LLM Model Settings
LLM_MODEL=qwen3.5-plus
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_TEMPERATURE=0.0

# ============================================
# ERP System Configuration
# ============================================
ERP_BASE_URL=https://erp.example.com
ERP_USERNAME=test_user
ERP_PASSWORD=your_password

# ============================================
# Database Configuration
# ============================================
# DATABASE_URL=sqlite+aiosqlite:///./data/database.db

# ============================================
# Server Configuration
# ============================================
# LOG_LEVEL=INFO

# ============================================
# Frontend Configuration (Vite)
# ============================================
# VITE_API_BASE=http://localhost:8080/api

# ============================================
# External Precondition Module Configuration
# ============================================
# Path to webseleniumerp project (optional)
# Required for using external precondition operations (FA1, HC1, etc.)
# The project must contain base_prerequisites.py and config/settings.py
# WEBSERP_PATH=/path/to/webseleniumerp
