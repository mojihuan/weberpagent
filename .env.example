# Chrome CDP 配置
CHROME_DEBUG_PORT=9222

# 服务器配置
PORT=3001

# LLM 配置
# LLM_PROVIDER: mock | openai | deepseek
LLM_PROVIDER=mock

# DeepSeek 配置（LLM_PROVIDER=deepseek 时需要）
# LLM_API_KEY=sk-xxx
# LLM_MODEL=deepseek-chat

# OpenAI 配置（LLM_PROVIDER=openai 时需要）
# LLM_API_KEY=sk-xxx
# LLM_MODEL=gpt-4o

# 浏览器配置
# BROWSER_MODE: launch（自动启动） | cdp（连接已有浏览器）
BROWSER_MODE=launch
# BROWSER_HEADLESS=true
# BROWSER_START_URL=https://example.com
# CDP_ENDPOINT=http://localhost:9222